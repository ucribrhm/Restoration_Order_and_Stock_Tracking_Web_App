@model Restaurant_Order_and_Stock_Tracking_Web_App.MVC.ViewModels.Onboarding.TenantRegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Restoranınızı Kaydedin";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestaurantOS — Yeni Restoran Kaydı</title>

    @* ── FOUC Önleme ── *@
    <script>
            (function () {
                var t = localStorage.getItem('ros-theme') || 'dark';
                document.documentElement.setAttribute('data-theme', t);
            })();
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700;1,800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>

    @* ── Arka Plan ── *@
    <div class="auth-bg" aria-hidden="true">
        <div class="auth-orb auth-orb-1"></div>
        <div class="auth-orb auth-orb-2"></div>
        <div class="auth-orb auth-orb-3"></div>
        <div class="auth-grid"></div>
    </div>

    <div class="auth-wrap auth-wrap--wide">

        @* ── Geri Link ── *@
        <a class="auth-back" href="/">
            <span class="auth-back-arrow">←</span>
            Ana Sayfaya Dön
        </a>

        <div class="auth-card">

            @* ── Logo ── *@
            <div class="auth-logo">
                <span class="auth-logo-icon" aria-hidden="true">🍽</span>
                <span class="auth-logo-text">RestaurantOS</span>
                <span class="auth-logo-sub">Yeni Restoran Kaydı · 30 Gün Ücretsiz</span>
            </div>

            <h1 class="auth-title">Hesap Oluşturun</h1>
            <p class="auth-subtitle">Restoranınızı dakikalar içinde sisteme ekleyin</p>

            @* ── Hata Bandı ── *@
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="auth-alert" role="alert">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            @*
            [FIX-405] Form action mutlak yol — asp-area="" .NET 9'da ambient area
            sızdırarak /Admin/Landing/Register üretebilir ve 405'e yol açar.
        *@
            <form action="/Landing/Register" method="post" id="registerForm" novalidate>
                @Html.AntiForgeryToken()

                @* ══════ BÖLÜM 1: Restoran Bilgileri ══════ *@
                <div class="auth-divider">🍽 Restoran Bilgileri</div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="RestaurantName">Restoran Adı</label>
                    <input class="auth-input @(ViewData.ModelState["RestaurantName"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="RestaurantName"
                           type="text"
                           autocomplete="organization"
                           placeholder="Örn: Burger Palace" />
                    @if (ViewData.ModelState["RestaurantName"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["RestaurantName"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="Subdomain">Subdomain</label>
                    <input class="auth-input @(ViewData.ModelState["Subdomain"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="Subdomain"
                           type="text"
                           autocomplete="off"
                           autocapitalize="none"
                           spellcheck="false"
                           placeholder="burger-palace"
                           id="subdomainInput" />
                    <span class="auth-hint">Yalnızca küçük harf, rakam ve tire. Örn: burger-palace</span>
                    @if (ViewData.ModelState["Subdomain"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["Subdomain"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ══════ BÖLÜM 2: Yönetici Hesabı ══════ *@
                <div class="auth-divider">👤 Yönetici Hesabı</div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="FullName">Ad Soyad</label>
                    <input class="auth-input @(ViewData.ModelState["FullName"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="FullName"
                           type="text"
                           autocomplete="name"
                           placeholder="Ahmet Yılmaz" />
                    @if (ViewData.ModelState["FullName"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["FullName"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="Username">Kullanıcı Adı</label>
                    <input class="auth-input @(ViewData.ModelState["Username"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="Username"
                           type="text"
                           autocomplete="username"
                           autocapitalize="none"
                           spellcheck="false"
                           placeholder="ahmet"
                           id="usernameInput" />
                    <span class="auth-hint">Sisteme giriş yaparken kullanacağınız kısa ad. Örn: ahmet</span>
                    @if (ViewData.ModelState["Username"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["Username"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                <div class="auth-field">
                    <label class="auth-label" asp-for="Email">E-posta <span style="opacity:0.55;font-weight:300">(isteğe bağlı)</span></label>
                    <input class="auth-input @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="Email"
                           type="email"
                           autocomplete="email"
                           placeholder="ahmet@burgerpalace.com" />
                    @if (ViewData.ModelState["Email"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["Email"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ── Şifre — Güç Göstergesi ── *@
                <div class="auth-field">
                    <label class="auth-label" asp-for="Password">Şifre</label>
                    <div class="auth-input-wrap">
                        <input class="auth-input @(ViewData.ModelState["Password"]?.Errors.Any() == true ? "is-invalid" : "")"
                               asp-for="Password"
                               type="password"
                               id="regPasswordInput"
                               autocomplete="new-password"
                               placeholder="En az 8 karakter" />
                        <button type="button" class="auth-pw-toggle" id="regPwToggle"
                                aria-label="Şifreyi göster / gizle"
                                data-target="regPasswordInput">
                            👁
                        </button>
                    </div>
                    @* Şifre güç göstergesi *@
                    <div class="pw-strength-wrap">
                        <div class="pw-strength-bar">
                            <div class="pw-strength-fill" id="pwStrengthFill"></div>
                        </div>
                        <span class="pw-strength-text" id="pwStrengthText"></span>
                    </div>
                    @if (ViewData.ModelState["Password"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["Password"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ── Şifre Tekrar — Anlık Eşleşme ── *@
                <div class="auth-field">
                    <label class="auth-label" asp-for="ConfirmPassword">Şifre Tekrar</label>
                    <div class="auth-input-wrap">
                        <input class="auth-input @(ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true ? "is-invalid" : "")"
                               asp-for="ConfirmPassword"
                               type="password"
                               id="confirmInput"
                               autocomplete="new-password"
                               placeholder="••••••••" />
                        <button type="button" class="auth-pw-toggle" id="confirmPwToggle"
                                aria-label="Şifreyi göster / gizle"
                                data-target="confirmInput">
                            👁
                        </button>
                    </div>
                    <div id="matchFeedback"></div>
                    @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["ConfirmPassword"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ── Submit ── *@
                <button type="submit" class="auth-submit" id="registerSubmit" style="margin-top:0.6rem">
                    <span class="auth-spinner" aria-hidden="true"></span>
                    <span class="auth-submit-text">Restoranımı Oluştur 🚀</span>
                </button>
            </form>

            @* ── Alt Linkler ── *@
            <div class="auth-footer">
                Zaten hesabınız var mı?
                <a asp-area="App" asp-controller="Auth" asp-action="Login">Giriş Yapın →</a>
            </div>

            <p class="auth-terms">
                Kaydolarak
                <a href="#">Kullanım Koşulları</a>'nı ve
                <a href="#">Gizlilik Politikası</a>'nı kabul etmiş olursunuz.
            </p>

        </div>
    </div>

    <script>
            (function () {
                'use strict';

                /* ── Şifre göster / gizle (tüm toggle butonlar) ──────────── */
                document.querySelectorAll('.auth-pw-toggle').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var inp = document.getElementById(this.getAttribute('data-target'));
                        if (!inp) return;
                        var isHidden = inp.type === 'password';
                        inp.type = isHidden ? 'text' : 'password';
                        this.textContent = isHidden ? '🙈' : '👁';
                        this.setAttribute('aria-label', isHidden ? 'Şifreyi gizle' : 'Şifreyi göster');
                    });
                });

                /* ── Şifre güç göstergesi ─────────────────────────────────── */
                var pwInput = document.getElementById('regPasswordInput');
                var fillEl  = document.getElementById('pwStrengthFill');
                var textEl  = document.getElementById('pwStrengthText');

                function checkStrength(pw) {
                    var score = 0;
                    if (pw.length >= 8)                    score++;
                    if (/[A-Z]/.test(pw))                  score++;
                    if (/[0-9]/.test(pw))                  score++;
                    if (/[^A-Za-z0-9]/.test(pw))           score++;
                    return score;
                }

                if (pwInput && fillEl && textEl) {
                    pwInput.addEventListener('input', function () {
                        var val = this.value;
                        if (!val) {
                            fillEl.style.width = '0%';
                            fillEl.className = 'pw-strength-fill';
                            textEl.textContent = '';
                            textEl.className = 'pw-strength-text';
                            return;
                        }
                        var s = checkStrength(val);
                        var level = s <= 1 ? 'weak' : s <= 2 ? 'medium' : 'strong';
                        var pct   = s <= 1 ? '33%' : s <= 2 ? '66%' : '100%';
                        var label = s <= 1 ? 'Zayıf' : s <= 2 ? 'Orta' : 'Güçlü';

                        fillEl.style.width = pct;
                        fillEl.className   = 'pw-strength-fill ' + level;
                        textEl.textContent = label;
                        textEl.className   = 'pw-strength-text ' + level;
                    });
                }

                /* ── Şifre eşleşme kontrolü ──────────────────────────────── */
                var confirmInput  = document.getElementById('confirmInput');
                var matchFeedback = document.getElementById('matchFeedback');

                if (confirmInput && matchFeedback && pwInput) {
                    function checkMatch() {
                        var pw  = pwInput.value;
                        var cfm = confirmInput.value;
                        if (!cfm) { matchFeedback.innerHTML = ''; return; }
                        if (pw === cfm) {
                            matchFeedback.innerHTML = '<span class="auth-match-ok">Şifreler eşleşiyor</span>';
                        } else {
                            matchFeedback.innerHTML = '<span class="auth-error">Şifreler eşleşmiyor</span>';
                        }
                    }
                    confirmInput.addEventListener('input', checkMatch);
                    pwInput.addEventListener('input', checkMatch);
                }

                /* ── Subdomain otomatik küçük harf / kısa çizgi ─────────── */
                var subInput = document.getElementById('subdomainInput');
                if (subInput) {
                    subInput.addEventListener('input', function () {
                        var raw = this.value
                            .toLowerCase()
                            .replace(/\s+/g, '-')
                            .replace(/[^a-z0-9\-]/g, '');
                        var pos = this.selectionStart;
                        this.value = raw;
                        try { this.setSelectionRange(pos, pos); } catch (e) { /* */ }
                    });
                }

                /* ── Submit spinner ──────────────────────────────────────── */
                var form = document.getElementById('registerForm');
                var btn  = document.getElementById('registerSubmit');
                if (form && btn) {
                    form.addEventListener('submit', function () {
                        btn.classList.add('loading');
                    });
                }
            })();
    </script>

</body>
</html>
