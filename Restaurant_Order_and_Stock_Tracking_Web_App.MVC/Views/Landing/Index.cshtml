@*
    Views/Landing/Index.cshtml
    RestaurantOS — Public Landing Page

    Sprint Redesign: Tam yeniden yazım
    Layout = null — Standalone, kendi CSS/JS'ini yükler
    Tasarım DNA: Koyu Mor (#1E1B4B) + Playfair Display + Lato + Glassmorphism
*@
@{
    Layout = null;
    ViewData["Title"] = "RestaurantOS — Restoranınızı Bir Sonraki Seviyeye Taşıyın";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestaurantOS — Restoranınızı Bir Sonraki Seviyeye Taşıyın</title>
    <meta name="description" content="Masa yönetimi, sipariş takibi, mutfak ekranı ve gerçek zamanlı raporlama. Türkiye'nin en gelişmiş restoran yönetim sistemi." />

    @* ── FOUC Önleme: Sayfa görüntülenmeden tema uygulanır ── *@
    <script>
            (function () {
                var t = localStorage.getItem('ros-theme') || 'dark';
                document.documentElement.setAttribute('data-theme', t);
            })();
    </script>

    @* ── Fontlar ── *@
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700;1,800;1,900&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" />

    @* ── Global Tema Değişkenleri ── *@
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />

    @* ── Sayfa CSS'i ── *@
    <link rel="stylesheet" href="~/css/Views/Landing/Index.css" asp-append-version="true" />
</head>
<body>

    @* ════════════════════════════════════════════════════════
   MOBILE OVERLAY MENU
   ════════════════════════════════════════════════════════ *@
    <div class="mobile-menu" id="mobileMenu">
        <button class="mobile-menu-close" id="mobileMenuClose" aria-label="Kapat">✕</button>
        <a class="mobile-nav-link" href="#features">Özellikler</a>
        <a class="mobile-nav-link" href="#pricing">Fiyatlandırma</a>
        <a class="mobile-nav-link" href="#about">Hakkımızda</a>
        <div class="mobile-nav-divider"></div>
        <a class="mobile-nav-link mobile-cta" asp-area="App" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
        <a class="mobile-btn-pill" asp-area="" asp-controller="Landing" asp-action="Register">Ücretsiz Başla →</a>
    </div>

    @* ════════════════════════════════════════════════════════
   NAVBAR
   ════════════════════════════════════════════════════════ *@
    <nav class="navbar" id="navbar" role="navigation">
        <a class="nav-logo" href="/">
            <span class="nav-logo-icon">🍽</span> RestaurantOS
        </a>

        <div class="nav-links" aria-label="Ana navigasyon">
            <a class="nav-link" href="#features">Özellikler</a>
            <a class="nav-link" href="#pricing">Fiyatlandırma</a>
            <a class="nav-link" href="#about">Hakkımızda</a>
        </div>

        <div class="nav-actions">
            <button class="theme-btn" id="themeBtn" aria-label="Tema değiştir" title="Dark / Light">🌙</button>
            <a class="btn-ghost" asp-area="App" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
            <a class="btn-pill" asp-area="" asp-controller="Landing" asp-action="Register">
                Hemen Başla <span aria-hidden="true">→</span>
            </a>
        </div>

        <button class="hamburger" id="hamburger" aria-label="Menü" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
    </nav>

    @* ════════════════════════════════════════════════════════
   HERO SECTION
   ════════════════════════════════════════════════════════ *@
    <section class="hero" id="hero">
        @* Animasyonlu arka plan orbs *@
        <div class="orbs-container" aria-hidden="true">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
            <div class="orb orb-4"></div>
        </div>

        @* İnce grid dokusu *@
        <div class="hero-grid-overlay" aria-hidden="true"></div>

        <div class="hero-content">
            <span class="hero-badge">
                <span class="hero-badge-dot" aria-hidden="true">✦</span>
                Yeni Nesil Restoran Yönetimi
            </span>

            <h1>
                Restoranınızı<br />
                Bir Sonraki<br />
                <em class="accent-text">Seviyeye</em> Taşıyın
            </h1>

            <p class="hero-sub">
                Masa yönetimi, sipariş takibi, mutfak ekranı ve gerçek zamanlı raporlama —
                hepsi tek bir güçlü platformda. Kurulum gerektirmez.
            </p>

            <div class="hero-cta">
                <a class="btn-pill btn-pill-lg" asp-area="" asp-controller="Landing" asp-action="Register">
                    Ücretsiz Deneyin →
                </a>
            </div>

            <p class="hero-note">
                <span>Kredi kartı gerekmez</span>
                <span class="hero-note-sep" aria-hidden="true">·</span>
                <span>14 gün ücretsiz</span>
                <span class="hero-note-sep" aria-hidden="true">·</span>
                <span>Anında kurulum</span>
            </p>
        </div>

        <div class="scroll-indicator" aria-hidden="true">
            <span>keşfet</span>
            <div class="scroll-arrow"></div>
        </div>
    </section>

    @* ════════════════════════════════════════════════════════
   SOSYAL KANIT — SAYAÇ BANDI
   ════════════════════════════════════════════════════════ *@
    <section class="stats-band" id="stats">
        <div class="stats-inner">
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-number" data-target="200" data-suffix="+">0</div>
                    <div class="stat-label">Aktif Restoran</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" data-target="50000" data-suffix="+" data-format="grouped">0</div>
                    <div class="stat-label">Günlük Sipariş</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" data-target="99" data-suffix=".9%">0</div>
                    <div class="stat-label">Uptime Garantisi</div>
                </div>
            </div>

            <p class="stats-headline">
                Türkiye'nin önde gelen restoranları RestaurantOS'a güveniyor
            </p>

            @* Restoran logoları marquee *@
            <div class="marquee-track" aria-hidden="true">
                <div class="marquee-inner">
                    @* İlk set *@
                    <span class="marquee-item">Bosphorus Steakhouse</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Kebap Sarayı</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Deniz Restaurant</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Osmanlı Sofrası</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Pasta Garden</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Urban Burger Co.</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Zeytinburnu Balık</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Lezzet Durağı</span>
                    <span class="marquee-sep">◆</span>
                    @* Sonsuz döngü için duplikat set *@
                    <span class="marquee-item">Bosphorus Steakhouse</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Kebap Sarayı</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Deniz Restaurant</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Osmanlı Sofrası</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Pasta Garden</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Urban Burger Co.</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Zeytinburnu Balık</span>
                    <span class="marquee-sep">◆</span>
                    <span class="marquee-item">Lezzet Durağı</span>
                    <span class="marquee-sep">◆</span>
                </div>
            </div>
        </div>
    </section>

    @* ════════════════════════════════════════════════════════
   ÖZELLİK KARTLARI
   ════════════════════════════════════════════════════════ *@
    <section class="features-section" id="features">
        <div class="section-header">
            <span class="section-eyebrow">Platform Özellikleri</span>
            <h2 class="section-title">
                Restoranınızın<br />
                <em>İhtiyaç Duyduğu Her Şey</em>
            </h2>
        </div>

        <div class="features-grid">
            @* Kart 1 *@
            <div class="feature-card scroll-reveal" style="--reveal-delay: 0ms">
                <div class="feature-icon-wrap" aria-hidden="true">🧾</div>
                <div class="feature-title">Akıllı Sipariş Yönetimi</div>
                <p class="feature-desc">
                    Masa bazlı adisyon oluşturun, QR menü ile müşteri siparişlerini alın.
                    Mutfak ekranında gerçek zamanlı sipariş takibi yapın.
                </p>
            </div>

            @* Kart 2 *@
            <div class="feature-card scroll-reveal" style="--reveal-delay: 100ms">
                <div class="feature-icon-wrap" aria-hidden="true">📊</div>
                <div class="feature-title">Canlı Raporlama</div>
                <p class="feature-desc">
                    Z-Raporu, vardiya takibi ve gelir/gider analizleri. Günlük, haftalık ve
                    aylık ciro raporlarını tek tıkla görün.
                </p>
            </div>

            @* Kart 3 *@
            <div class="feature-card scroll-reveal" style="--reveal-delay: 200ms">
                <div class="feature-icon-wrap" aria-hidden="true">🔔</div>
                <div class="feature-title">Anlık Bildirimler</div>
                <p class="feature-desc">
                    SignalR teknolojisiyle garson çağrısı, mutfak-salon iletişimi ve
                    düşük stok uyarıları anında iletilir.
                </p>
            </div>

            @* Kart 4 *@
            <div class="feature-card scroll-reveal" style="--reveal-delay: 0ms">
                <div class="feature-icon-wrap" aria-hidden="true">🪑</div>
                <div class="feature-title">Masa Yönetimi</div>
                <p class="feature-desc">
                    Masaların anlık durumunu takip edin, birleştirin veya rezerve edin.
                    Oturum süreleri otomatik hesaplanır.
                </p>
            </div>

            @* Kart 5 *@
            <div class="feature-card scroll-reveal" style="--reveal-delay: 100ms">
                <div class="feature-icon-wrap" aria-hidden="true">📦</div>
                <div class="feature-title">Stok Takibi</div>
                <p class="feature-desc">
                    Kritik stok uyarıları alın, israfı önleyin. Hammadde bazında
                    tüketim analizi ile maliyetlerinizi düşürün.
                </p>
            </div>

            @* Kart 6 *@
            <div class="feature-card scroll-reveal" style="--reveal-delay: 200ms">
                <div class="feature-icon-wrap" aria-hidden="true">👥</div>
                <div class="feature-title">Personel Yönetimi</div>
                <p class="feature-desc">
                    Admin, Garson, Kasiyer ve Mutfak rolleriyle erişim yönetimi.
                    Her çalışan yalnızca kendi sayfalarını görür.
                </p>
            </div>
        </div>
    </section>

    @* ════════════════════════════════════════════════════════
   CTA BANDI
   ════════════════════════════════════════════════════════ *@
    <section class="cta-band scroll-reveal">
        <div class="cta-band-inner">
            <div class="cta-band-orb" aria-hidden="true"></div>
            <span class="section-eyebrow">Ücretsiz Başlayın</span>
            <h2 class="cta-band-title">
                Bugün Kaydolun,<br />
                <em>Yarın Fark Yaratın</em>
            </h2>
            <p class="cta-band-sub">
                Kurulum gerektirmez. 14 gün boyunca tüm özellikleri ücretsiz deneyin.
            </p>
            <a class="btn-pill btn-pill-lg" asp-area="" asp-controller="Landing" asp-action="Register">
                Restoranımı Kaydet →
            </a>
        </div>
    </section>

    @* ════════════════════════════════════════════════════════
   FOOTER
   ════════════════════════════════════════════════════════ *@
    <footer class="footer" id="about">
        <div class="footer-inner">
            <div class="footer-grid">

                @* Kolon 1: Marka *@
                <div class="footer-brand">
                    <div class="footer-logo">
                        <span aria-hidden="true">🍽</span> RestaurantOS
                    </div>
                    <p class="footer-tagline">
                        Türkiye'nin en gelişmiş restoran yönetim sistemi.
                        Küçük kafeden büyük restorana, her ölçekte çalışır.
                    </p>
                    <div class="footer-socials" aria-label="Sosyal medya">
                        <a class="social-btn" href="#" aria-label="X (Twitter)">𝕏</a>
                        <a class="social-btn" href="#" aria-label="Facebook">📘</a>
                        <a class="social-btn" href="#" aria-label="Instagram">📸</a>
                        <a class="social-btn" href="#" aria-label="LinkedIn">💼</a>
                    </div>
                </div>

                @* Kolon 2: Ürün *@
                <div class="footer-col">
                    <div class="footer-col-title">Ürün</div>
                    <nav class="footer-links" aria-label="Ürün bağlantıları">
                        <a class="footer-link" href="#features">Özellikler</a>
                        <a class="footer-link" href="#pricing">Fiyatlandırma</a>
                        <a class="footer-link" href="#">Demo İste</a>
                        <a class="footer-link" href="#">Güncellemeler</a>
                        <a class="footer-link" href="#">API Dokümantasyonu</a>
                    </nav>
                </div>

                @* Kolon 3: Şirket *@
                <div class="footer-col">
                    <div class="footer-col-title">Şirket</div>
                    <nav class="footer-links" aria-label="Şirket bağlantıları">
                        <a class="footer-link" href="#about">Hakkımızda</a>
                        <a class="footer-link" href="#">Blog</a>
                        <a class="footer-link" href="#">Kariyer</a>
                        <a class="footer-link" href="#">Basın</a>
                        <a class="footer-link" href="#">İş Ortaklığı</a>
                    </nav>
                </div>

                @* Kolon 4: İletişim *@
                <div class="footer-col">
                    <div class="footer-col-title">İletişim</div>
                    <div class="footer-contact">
                        <div class="footer-contact-item">
                            <span class="fci-icon" aria-hidden="true">✉</span>
                            <span>destek@restaurantos.com</span>
                        </div>
                        <div class="footer-contact-item">
                            <span class="fci-icon" aria-hidden="true">📞</span>
                            <span>+90 212 000 00 00</span>
                        </div>
                        <div class="footer-contact-item">
                            <span class="fci-icon" aria-hidden="true">📍</span>
                            <span>İstanbul, Türkiye</span>
                        </div>
                        <div class="footer-contact-item">
                            <span class="fci-icon" aria-hidden="true">💬</span>
                            <span>7/24 Canlı Destek</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <span class="footer-copy">
                    © @DateTime.Now.Year RestaurantOS — Tüm hakları saklıdır.
                </span>
                <nav class="footer-legal" aria-label="Yasal bağlantılar">
                    <a class="footer-legal-link" href="#">Gizlilik Politikası</a>
                    <a class="footer-legal-link" href="#">Kullanım Koşulları</a>
                    <a class="footer-legal-link" href="#">KVKK</a>
                </nav>
            </div>
        </div>
    </footer>

    @* ── Sayfa JS'i ── *@
    <script src="~/js/Views/Landing/Index.js" asp-append-version="true"></script>

</body>
</html>
