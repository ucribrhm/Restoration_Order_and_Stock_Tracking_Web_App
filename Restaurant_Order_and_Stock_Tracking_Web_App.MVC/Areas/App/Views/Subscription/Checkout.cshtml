@*
    ════════════════════════════════════════════════════════════════════════
    Areas/App/Views/Subscription/Checkout.cshtml  —  Sahte Ödeme Formu
    ════════════════════════════════════════════════════════════════════════
*@
@{
    ViewData["Title"] = "Ödeme";
    Layout = "_AppLayout";

    var selectedPlan = ViewBag.SelectedPlan as string ?? "pro";
    var planPrice = ViewBag.PlanPrice as string ?? "₺999 / ay";
    var planLabel = ViewBag.PlanLabel as string ?? "⚡ Pro";
    var restName = ViewBag.RestaurantName as string ?? "";
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap');

        :root {
            --bg: #0a0a0f;
            --surface: #13131e;
            --surface2: #1a1a28;
            --border: rgba(255,255,255,.07);
            --border2: rgba(255,255,255,.13);
            --accent: #f97316;
            --accent-lt: rgba(249,115,22,.12);
            --purple: #a855f7;
            --purple-lt: rgba(168,85,247,.12);
            --green: #22c55e;
            --green-lt: rgba(34,197,94,.12);
            --text: #f0ece8;
            --text2: #9994a8;
            --text3: #5a5668;
            --font: 'Outfit', sans-serif;
            --r: 18px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .co-wrap {
            font-family: var(--font);
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 48px 20px 80px;
            gap: 32px;
            flex-wrap: wrap;
            background: radial-gradient(ellipse 70% 50% at 20% 20%, rgba(168,85,247,.08), transparent), radial-gradient(ellipse 60% 40% at 80% 70%, rgba(249,115,22,.06), transparent);
        }

        /* ── Sol panel: kart önizleme + sipariş özeti ── */
        .co-left {
            width: 340px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* ── Sahte kredi kartı ── */
        .cc-card {
            width: 340px;
            height: 200px;
            border-radius: 18px;
            padding: 24px;
            background: linear-gradient(135deg, #1e1b4b 0%, #3730a3 50%, #1e40af 100%);
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.08);
            transition: transform .3s ease;
        }

            .cc-card:hover {
                transform: rotateY(5deg) rotateX(3deg);
            }

            .cc-card::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: rgba(255,255,255,.06);
                pointer-events: none;
            }

            .cc-card::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: -20px;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: rgba(255,255,255,.04);
                pointer-events: none;
            }

        .cc-chip {
            width: 42px;
            height: 32px;
            background: linear-gradient(135deg, #d4a017, #f5c842);
            border-radius: 6px;
            margin-bottom: 24px;
            position: relative;
            z-index: 1;
        }

            .cc-chip::before {
                content: '';
                position: absolute;
                inset: 5px;
                border: 1px solid rgba(0,0,0,.25);
                border-radius: 3px;
            }

        .cc-number {
            font-size: 19px;
            font-weight: 700;
            letter-spacing: 3px;
            color: #fff;
            margin-bottom: 20px;
            font-variant-numeric: tabular-nums;
            position: relative;
            z-index: 1;
        }

        .cc-bottom {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            position: relative;
            z-index: 1;
        }

        .cc-label {
            font-size: 9px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: rgba(255,255,255,.5);
            margin-bottom: 3px;
        }

        .cc-value {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            letter-spacing: .5px;
        }

        .cc-brand {
            font-size: 28px;
            font-weight: 900;
            font-style: italic;
            background: linear-gradient(135deg, #e2e8f0, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ── Sipariş özeti kartı ── */
        .co-summary {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: var(--r);
            padding: 20px;
        }

        .co-summary-title {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--text3);
            margin-bottom: 14px;
        }

        .co-summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: var(--text2);
            padding: 6px 0;
            border-bottom: 1px solid var(--border);
        }

            .co-summary-row:last-child {
                border-bottom: none;
            }

        .co-summary-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 14px;
            margin-top: 6px;
        }

            .co-summary-total span:first-child {
                font-size: 14px;
                font-weight: 700;
                color: var(--text);
            }

            .co-summary-total span:last-child {
                font-size: 20px;
                font-weight: 900;
                color: var(--accent);
            }

        /* ── Güvenlik rozetleri ── */
        .co-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .co-badge {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 10px;
            font-weight: 600;
            color: var(--green);
            background: var(--green-lt);
            border: 1px solid rgba(34,197,94,.2);
            padding: 4px 10px;
            border-radius: 99px;
        }

        /* ── Sağ panel: form ── */
        .co-right {
            width: 380px;
            flex-shrink: 0;
        }

        .co-form-card {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: var(--r);
            padding: 28px;
        }

        .co-form-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 4px;
        }

        .co-form-sub {
            font-size: 12px;
            color: var(--text3);
            margin-bottom: 24px;
        }

        .co-field {
            margin-bottom: 16px;
        }

            .co-field label {
                display: block;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .7px;
                color: var(--text3);
                margin-bottom: 7px;
            }

            .co-field input {
                width: 100%;
                background: var(--surface2);
                border: 1px solid var(--border2);
                border-radius: 10px;
                padding: 12px 14px;
                font: 600 14px var(--font);
                color: var(--text);
                outline: none;
                transition: border-color .18s, box-shadow .18s;
                font-variant-numeric: tabular-nums;
            }

                .co-field input:focus {
                    border-color: rgba(168,85,247,.5);
                    box-shadow: 0 0 0 3px rgba(168,85,247,.12);
                }

                .co-field input::placeholder {
                    color: var(--text3);
                    font-weight: 500;
                }

        .co-row {
            display: flex;
            gap: 12px;
        }

            .co-row .co-field {
                flex: 1;
            }

        /* ── Plan seçim şeridi ── */
        .co-plan-pill {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(168,85,247,.10);
            border: 1px solid rgba(168,85,247,.25);
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 20px;
        }

        .co-plan-pill-label {
            font-size: 13px;
            font-weight: 700;
            color: #c084fc;
        }

        .co-plan-pill-price {
            font-size: 15px;
            font-weight: 900;
            color: var(--text);
        }

        /* ── Ödeme butonu ── */
        .co-pay-btn {
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            background: linear-gradient(135deg, #a855f7, #818cf8);
            color: #fff;
            font: 700 15px var(--font);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 20px rgba(168,85,247,.4);
            transition: transform .15s, box-shadow .15s, filter .15s;
            margin-top: 8px;
            letter-spacing: .2px;
        }

            .co-pay-btn:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 8px 32px rgba(168,85,247,.55);
                filter: brightness(1.05);
            }

            .co-pay-btn:active {
                transform: scale(.98);
            }

            .co-pay-btn:disabled {
                opacity: .7;
                cursor: not-allowed;
                transform: none;
            }

        /* Yükleniyor spinner */
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .co-spinner {
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: none;
        }

        .co-pay-btn.loading .co-spinner {
            display: block;
        }

        .co-pay-btn.loading .co-btn-text {
            display: none;
        }

        .co-disclaimer {
            font-size: 10px;
            color: var(--text3);
            text-align: center;
            margin-top: 12px;
            line-height: 1.6;
        }

        /* ── Geri dön linki ── */
        .co-back {
            text-align: center;
            margin-top: 16px;
            font-size: 12px;
            color: var(--text3);
        }

            .co-back a {
                color: var(--text2);
                text-decoration: none;
                font-weight: 600;
            }

                .co-back a:hover {
                    color: var(--text);
                    text-decoration: underline;
                }

        @@media(max-width: 780px) {
            .co-wrap {
                flex-direction: column;
                align-items: center;
            }

            .co-left, .co-right {
                width: 100%;
                max-width: 420px;
            }

            .cc-card {
                width: 100%;
            }
        }
    </style>
}

<div class="co-wrap">

    @* ── Sol Panel ─────────────────────────────────────────────────────── *@
    <div class="co-left">

        @* Sahte Kredi Kartı Önizlemesi *@
        <div class="cc-card" id="ccPreview">
            <div class="cc-chip"></div>
            <div class="cc-number" id="ccNumberPreview">•••• •••• •••• ••••</div>
            <div class="cc-bottom">
                <div>
                    <div class="cc-label">Kart Sahibi</div>
                    <div class="cc-value" id="ccHolderPreview">AD SOYAD</div>
                </div>
                <div>
                    <div class="cc-label">Son Tarih</div>
                    <div class="cc-value" id="ccExpiryPreview">MM/YY</div>
                </div>
                <div class="cc-brand">VISA</div>
            </div>
        </div>

        @* Sipariş Özeti *@
        <div class="co-summary">
            <div class="co-summary-title">Sipariş Özeti</div>
            <div class="co-summary-row">
                <span>@restName</span>
                <span>@planLabel</span>
            </div>
            <div class="co-summary-row">
                <span>Plan</span>
                <span>@planLabel</span>
            </div>
            <div class="co-summary-row">
                <span>Faturalama</span>
                <span>Aylık</span>
            </div>
            <div class="co-summary-row">
                <span>KDV (%18)</span>
                <span>Dahil</span>
            </div>
            <div class="co-summary-total">
                <span>Toplam</span>
                <span>@planPrice</span>
            </div>
        </div>

        @* Güvenlik Rozetleri *@
        <div class="co-badges">
            <span class="co-badge">🔒 SSL Şifreli</span>
            <span class="co-badge">✓ 256-bit Güvenli</span>
            <span class="co-badge">🛡️ PCI DSS</span>
        </div>

    </div>

    @* ── Sağ Panel: Form ────────────────────────────────────────────────── *@
    <div class="co-right">
        <div class="co-form-card">

            <div class="co-form-title">💳 Ödeme Bilgileri</div>
            <div class="co-form-sub">Tüm işlemler güvenli şifreleme ile korunmaktadır.</div>

            <div class="co-plan-pill">
                <span class="co-plan-pill-label">@planLabel Paketi</span>
                <span class="co-plan-pill-price">@planPrice</span>
            </div>

            <form method="post"
                  asp-area="App"
                  asp-controller="Subscription"
                  asp-action="ProcessPayment"
                  id="checkoutForm"
                  novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="plan" value="@selectedPlan" />

                <div class="co-field">
                    <label>Kart Numarası</label>
                    <input type="text"
                           name="cardNumber"
                           id="cardNumber"
                           placeholder="0000 0000 0000 0000"
                           maxlength="19"
                           autocomplete="cc-number"
                           inputmode="numeric"
                           required />
                </div>

                <div class="co-field">
                    <label>Kart Üzerindeki İsim</label>
                    <input type="text"
                           name="cardHolder"
                           id="cardHolder"
                           placeholder="AD SOYAD"
                           autocomplete="cc-name"
                           required />
                </div>

                <div class="co-row">
                    <div class="co-field">
                        <label>Son Kullanma Tarihi</label>
                        <input type="text"
                               name="expiryDate"
                               id="expiryDate"
                               placeholder="MM/YY"
                               maxlength="5"
                               autocomplete="cc-exp"
                               inputmode="numeric"
                               required />
                    </div>
                    <div class="co-field">
                        <label>CVV</label>
                        <input type="password"
                               name="cvv"
                               id="cvv"
                               placeholder="•••"
                               maxlength="4"
                               autocomplete="cc-csc"
                               inputmode="numeric"
                               required />
                    </div>
                </div>

                <button type="submit" class="co-pay-btn" id="payBtn">
                    <span class="co-spinner"></span>
                    <span class="co-btn-text">🔒 @planPrice — Ödemeyi Tamamla</span>
                </button>

            </form>

            <p class="co-disclaimer">
                Bu demo ortamında gerçek ödeme alınmamaktadır.<br>
                Herhangi bir kart bilgisi girebilirsiniz.
            </p>
        </div>

        <div class="co-back">
            <a asp-area="App" asp-controller="Subscription" asp-action="Upgrade">
                ← Plan karşılaştırmasına dön
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // ── Kart numarası formatlama (xxxx xxxx xxxx xxxx) ──────────────────────
        const cardNumberEl = document.getElementById('cardNumber');
        const ccNumPrev    = document.getElementById('ccNumberPreview');

        cardNumberEl.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').slice(0, 16);
            this.value = v.replace(/(\d{4})(?=\d)/g, '$1 ');
            const padded = (v + '????????????????').slice(0, 16);
            ccNumPrev.textContent = padded.replace(/(\d{4})(?=\d)/g, '$1 ').replace(/\?/g, '•');
        });

        // ── Kart sahibi önizleme ─────────────────────────────────────────────────
        const cardHolderEl = document.getElementById('cardHolder');
        const ccHolderPrev = document.getElementById('ccHolderPreview');

        cardHolderEl.addEventListener('input', function () {
            ccHolderPrev.textContent = this.value.toUpperCase() || 'AD SOYAD';
        });

        // ── Son tarih formatlama (MM/YY) ─────────────────────────────────────────
        const expiryEl   = document.getElementById('expiryDate');
        const ccExpPrev  = document.getElementById('ccExpiryPreview');

        expiryEl.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').slice(0, 4);
            if (v.length >= 3) v = v.slice(0, 2) + '/' + v.slice(2);
            this.value = v;
            ccExpPrev.textContent = v || 'MM/YY';
        });

        // ── Form gönderimi: buton loading state ──────────────────────────────────
        const form   = document.getElementById('checkoutForm');
        const payBtn = document.getElementById('payBtn');

        form.addEventListener('submit', function (e) {
            // Basit doğrulama
            const num = cardNumberEl.value.replace(/\s/g, '');
            if (num.length < 16) { e.preventDefault(); cardNumberEl.focus(); return; }

            const exp = expiryEl.value;
            if (exp.length < 5) { e.preventDefault(); expiryEl.focus(); return; }

            const cv = document.getElementById('cvv').value;
            if (cv.length < 3) { e.preventDefault(); document.getElementById('cvv').focus(); return; }

            // Loading state — 2 sn sunucu gecikme simülasyonu sırasında gösterilir
            payBtn.disabled = true;
            payBtn.classList.add('loading');
        });
    </script>
}
