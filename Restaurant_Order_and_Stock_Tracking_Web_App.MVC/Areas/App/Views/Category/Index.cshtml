@model IEnumerable<Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.Category>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "_AppLayout";
}

@section Styles {
    <link href="~/css/Views/Category/Index.css" rel="stylesheet" asp-append-version="true" />
    <style>
        .lang-tabs-wrapper {
            margin-bottom: 1rem;
            border-bottom: 1px solid var(--border, rgba(255,255,255,.1));
        }

        .lang-tabs {
            display: flex;
            gap: 0;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .lang-tab-btn {
            background: none;
            border: none;
            border-bottom: 2px solid transparent;
            padding: .5rem 1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .78rem;
            font-weight: 600;
            letter-spacing: .08em;
            color: var(--text-muted, rgba(255,255,255,.4));
            cursor: pointer;
            transition: color .18s, border-color .18s;
            margin-bottom: -1px;
        }

            .lang-tab-btn.active,
            .lang-tab-btn[aria-selected="true"] {
                color: #F97316;
                border-bottom-color: #F97316;
            }

            .lang-tab-btn:hover:not(.active) {
                color: var(--text, rgba(255,255,255,.75));
            }

        [data-theme="light"] .lang-tab-btn {
            color: #6b7280;
        }

            [data-theme="light"] .lang-tab-btn.active {
                color: #F97316;
                border-bottom-color: #F97316;
            }

        .lang-tab-content {
            padding-top: .15rem;
        }

        .lang-flag {
            font-size: .9rem;
            margin-right: .2rem;
        }

        .required-star {
            color: #ef4444;
            font-weight: 700;
        }

        .optional-badge {
            font-size: .68rem;
            font-weight: 400;
            opacity: .5;
            letter-spacing: 0;
            text-transform: none;
            margin-left: .3rem;
        }

        .rtl-input {
            font-family: 'Noto Sans Arabic', 'DM Sans', sans-serif;
        }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">🗂️ Kategoriler</h1>
        <div class="page-subtitle">@Model.Count() kategori listeleniyor</div>
    </div>
    <button class="btn btn-primary" onclick="openCreateModal()">
        ＋ Yeni Kategori
    </button>
</div>

<div class="card">
    <table class="ros-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Kategori Adı</th>
                <th>Sıra</th>
                <th>Ürün Sayısı</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <div class="empty-state-icon">🗂️</div>
                            <div class="empty-state-text">Henüz kategori eklenmemiş.</div>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var cat in Model)
            {
                <tr>
                    <td style="opacity:.4; font-size:.8rem;">@cat.CategoryId</td>
                    <td>
                        <div style="font-weight:600;">@cat.CategoryName</div>
                        @if (!string.IsNullOrWhiteSpace(cat.NameEn) || !string.IsNullOrWhiteSpace(cat.NameAr) || !string.IsNullOrWhiteSpace(cat.NameRu))
                        {
                            <div style="font-size:.72rem; opacity:.4; margin-top:.15rem;">
                                @if (!string.IsNullOrWhiteSpace(cat.NameEn))
                                {
                                    <span>EN ✓</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(cat.NameAr))
                                {
                                    <span style="margin-left:.35rem;">AR ✓</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(cat.NameRu))
                                {
                                    <span style="margin-left:.35rem;">RU ✓</span>
                                }
                            </div>
                        }
                    </td>
                    <td><span class="pill pill-indigo">@cat.CategorySortOrder</span></td>
                    <td><span class="pill pill-indigo">@(cat.MenuItems?.Count ?? 0) ürün</span></td>
                    <td>
                        @if (cat.IsActive)
                        {
                            <span class="pill pill-green">✓ Aktif</span>
                        }
                        else
                        {
                            <span class="pill pill-red">✗ Pasif</span>
                        }
                    </td>
                    <td>
                        <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                            <a asp-action="Detail" asp-route-id="@cat.CategoryId" class="btn btn-detail btn-sm">👁 Detay</a>
                            <button class="btn btn-edit btn-sm" onclick="openEditModal(@cat.CategoryId)">✏️ Düzenle</button>
                            <button class="btn btn-delete btn-sm" onclick="openDeleteModal(@cat.CategoryId, '@cat.CategoryName')">🗑 Sil</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- CREATE MODAL -->
<div class="modal-overlay" id="createModal">
    <div class="modal">
        <div class="modal-header">
            <h2 class="modal-title">➕ Yeni Kategori</h2>
            <button class="modal-close" onclick="closeModal('createModal')">✕</button>
        </div>
        <form id="createForm">
            @Html.AntiForgeryToken()

            <div class="lang-tabs-wrapper">
                <ul class="lang-tabs" role="tablist" id="createLangTabs">
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn active" role="tab" aria-selected="true"
                                data-target="c-pane-tr" onclick="switchTab(this,'createLangTabs')">
                            <span class="lang-flag">🇹🇷</span> TR
                        </button>
                    </li>
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn" role="tab" aria-selected="false"
                                data-target="c-pane-en" onclick="switchTab(this,'createLangTabs')">
                            <span class="lang-flag">🇬🇧</span> EN
                        </button>
                    </li>
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn" role="tab" aria-selected="false"
                                data-target="c-pane-ar" onclick="switchTab(this,'createLangTabs')">
                            <span class="lang-flag">🇸🇦</span> AR
                        </button>
                    </li>
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn" role="tab" aria-selected="false"
                                data-target="c-pane-ru" onclick="switchTab(this,'createLangTabs')">
                            <span class="lang-flag">🇷🇺</span> RU
                        </button>
                    </li>
                </ul>
            </div>

            <div class="lang-tab-content">
                <div id="c-pane-tr" class="lang-pane">
                    <div class="form-group">
                        <label class="form-label">Kategori Adı <span class="required-star">*</span></label>
                        <input type="text" id="create_categoryName" class="form-control"
                               placeholder="örn. İçecekler" maxlength="100" required />
                    </div>
                </div>
                <div id="c-pane-en" class="lang-pane" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">Category Name <span class="optional-badge">(opsiyonel)</span></label>
                        <input type="text" id="create_nameEn" class="form-control"
                               placeholder="e.g. Beverages" maxlength="100" />
                    </div>
                </div>
                <div id="c-pane-ar" class="lang-pane" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">اسم الفئة <span class="optional-badge">(opsiyonel)</span></label>
                        <input type="text" id="create_nameAr" class="form-control rtl-input"
                               placeholder="مثال: المشروبات" maxlength="100" dir="rtl" />
                    </div>
                </div>
                <div id="c-pane-ru" class="lang-pane" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">Название категории <span class="optional-badge">(opsiyonel)</span></label>
                        <input type="text" id="create_nameRu" class="form-control"
                               placeholder="например: Напитки" maxlength="100" />
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Sıralama</label>
                    <input type="number" id="create_sortOrder" class="form-control" value="0" min="0" />
                </div>
                <div class="form-group" style="display:flex;flex-direction:column;justify-content:flex-end;">
                    <label class="form-label">Durum</label>
                    <div class="toggle-group">
                        <label class="toggle-switch">
                            <input type="checkbox" id="create_isActive" checked />
                            <span class="toggle-slider"></span>
                        </label>
                        <span class="toggle-label-text">Aktif</span>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('createModal')">İptal</button>
                <button type="submit" class="btn btn-primary">💾 Kaydet</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal-overlay" id="editModal">
    <div class="modal">
        <div class="modal-header">
            <h2 class="modal-title">✏️ Kategori Düzenle</h2>
            <button class="modal-close" onclick="closeModal('editModal')">✕</button>
        </div>
        <form id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="edit_id" />

            <div class="lang-tabs-wrapper">
                <ul class="lang-tabs" role="tablist" id="editLangTabs">
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn active" role="tab" aria-selected="true"
                                data-target="e-pane-tr" onclick="switchTab(this,'editLangTabs')">
                            <span class="lang-flag">🇹🇷</span> TR
                        </button>
                    </li>
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn" role="tab" aria-selected="false"
                                data-target="e-pane-en" onclick="switchTab(this,'editLangTabs')">
                            <span class="lang-flag">🇬🇧</span> EN
                        </button>
                    </li>
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn" role="tab" aria-selected="false"
                                data-target="e-pane-ar" onclick="switchTab(this,'editLangTabs')">
                            <span class="lang-flag">🇸🇦</span> AR
                        </button>
                    </li>
                    <li role="presentation">
                        <button type="button" class="lang-tab-btn" role="tab" aria-selected="false"
                                data-target="e-pane-ru" onclick="switchTab(this,'editLangTabs')">
                            <span class="lang-flag">🇷🇺</span> RU
                        </button>
                    </li>
                </ul>
            </div>

            <div class="lang-tab-content">
                <div id="e-pane-tr" class="lang-pane">
                    <div class="form-group">
                        <label class="form-label">Kategori Adı <span class="required-star">*</span></label>
                        <input type="text" id="edit_categoryName" class="form-control" maxlength="100" required />
                    </div>
                </div>
                <div id="e-pane-en" class="lang-pane" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">Category Name <span class="optional-badge">(opsiyonel)</span></label>
                        <input type="text" id="edit_nameEn" class="form-control" maxlength="100" />
                    </div>
                </div>
                <div id="e-pane-ar" class="lang-pane" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">اسم الفئة <span class="optional-badge">(opsiyonel)</span></label>
                        <input type="text" id="edit_nameAr" class="form-control rtl-input" maxlength="100" dir="rtl" />
                    </div>
                </div>
                <div id="e-pane-ru" class="lang-pane" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">Название категории <span class="optional-badge">(opsiyonel)</span></label>
                        <input type="text" id="edit_nameRu" class="form-control" maxlength="100" />
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Sıralama</label>
                    <input type="number" id="edit_sortOrder" class="form-control" min="0" />
                </div>
                <div class="form-group" style="display:flex;flex-direction:column;justify-content:flex-end;">
                    <label class="form-label">Durum</label>
                    <div class="toggle-group">
                        <label class="toggle-switch">
                            <input type="checkbox" id="edit_isActive" />
                            <span class="toggle-slider"></span>
                        </label>
                        <span class="toggle-label-text">Aktif</span>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('editModal')">İptal</button>
                <button type="submit" class="btn btn-primary">💾 Güncelle</button>
            </div>
        </form>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal confirm-modal">
        <div class="confirm-icon">🗑️</div>
        <h2 class="modal-title" style="margin-bottom:.5rem;">Silme Onayı</h2>
        <p class="confirm-text">
            <span class="confirm-name" id="delete_name"></span> kategorisini silmek istediğinizden emin misiniz?
            <br><small>Bu işlem geri alınamaz.</small>
        </p>
        <form id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="delete_id" />
            <div style="display:flex;justify-content:center;gap:.75rem;">
                <button type="button" class="btn btn-ghost" onclick="closeModal('deleteModal')">İptal</button>
                <button type="submit" class="btn btn-delete">🗑 Evet, Sil</button>
            </div>
        </form>
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>

@section Scripts {
    <script src="~/js/Views/Category/Index.js" asp-append-version="true"></script>
}