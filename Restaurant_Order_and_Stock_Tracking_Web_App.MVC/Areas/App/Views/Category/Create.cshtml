@{
    ViewData["Title"] = "Yeni Kategori";
    Layout = "_AppLayout";
}

@section Styles {
    <link href="~/css/Views/Category/Create.css" rel="stylesheet" asp-append-version="true" />
}

<div class="form-page">
    <div class="page-header">
        <div><h1 class="page-title">➕ Yeni Kategori</h1></div>
        <a asp-action="Index" class="btn btn-ghost">← Geri</a>
    </div>

    <div class="card">
        <form id="createForm">
            @Html.AntiForgeryToken()
            <div id="alertBox" class="alert alert-error" style="display:none;"></div>

            @* ── Dil Sekmeleri ── *@
            <div class="lang-tabs">
                <button type="button" class="lang-tab active" data-lang="tr" onclick="switchLangTab('tr', this)">🇹🇷 Türkçe</button>
                <button type="button" class="lang-tab" data-lang="en" onclick="switchLangTab('en', this)">🇬🇧 English</button>
                <button type="button" class="lang-tab" data-lang="ar" onclick="switchLangTab('ar', this)">🇸🇦 العربية</button>
                <button type="button" class="lang-tab" data-lang="ru" onclick="switchLangTab('ru', this)">🇷🇺 Русский</button>
            </div>

            @* TR *@
            <div class="lang-panel active" id="panel-tr">
                <div class="form-group">
                    <label class="form-label">Kategori Adı (TR) *</label>
                    <input type="text" id="c_nameTr" class="form-control" placeholder="örn. İçecekler" maxlength="100" />
                </div>
            </div>

            @* EN *@
            <div class="lang-panel" id="panel-en" style="display:none">
                <div class="form-group">
                    <label class="form-label">Category Name (EN)</label>
                    <input type="text" id="c_nameEn" class="form-control" placeholder="e.g. Beverages" maxlength="100" />
                </div>
            </div>

            @* AR *@
            <div class="lang-panel" id="panel-ar" style="display:none">
                <div class="form-group">
                    <label class="form-label">اسم الفئة (AR)</label>
                    <input type="text" id="c_nameAr" class="form-control" dir="rtl" placeholder="مثال: المشروبات" maxlength="100" />
                </div>
            </div>

            @* RU *@
            <div class="lang-panel" id="panel-ru" style="display:none">
                <div class="form-group">
                    <label class="form-label">Название категории (RU)</label>
                    <input type="text" id="c_nameRu" class="form-control" placeholder="напр. Напитки" maxlength="100" />
                </div>
            </div>

            @* Ortak alanlar *@
            <div class="form-row" style="margin-top:16px">
                <div class="form-group">
                    <label class="form-label">Sıralama</label>
                    <input type="number" id="c_sortOrder" class="form-control" value="0" min="0" />
                </div>
                <div class="form-group" style="display:flex;flex-direction:column;justify-content:flex-end;">
                    <label class="form-label">Durum</label>
                    <div class="toggle-group">
                        <label class="toggle-switch">
                            <input type="checkbox" id="c_isActive" checked />
                            <span class="toggle-slider"></span>
                        </label>
                        <span>Aktif</span>
                    </div>
                </div>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:.6rem;margin-top:1.5rem;">
                <a asp-action="Index" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">💾 Kaydet</button>
            </div>
        </form>
    </div>
</div>

<style>
    .lang-tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .lang-tab {
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid var(--border,#e5e7eb);
        background: var(--surface2,#f9fafb);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all .18s;
    }

        .lang-tab.active {
            background: var(--accent,#f97316);
            color: #fff;
            border-color: var(--accent,#f97316);
        }
</style>

@section Scripts {
    <script src="~/js/Views/Category/Create.js" asp-append-version="true"></script>
}