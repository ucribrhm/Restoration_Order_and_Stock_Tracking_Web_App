@{
    ViewData["Title"] = "Vardiya Aç";
}

@section Styles {
    <link href="~/css/Views/Shift/Index.css" rel="stylesheet" asp-append-version="true" />
    <style>
        /* ════════════════════════════════════════════════════
                   Shift/Open — Premium Input & CTA Layer
                   Mevcut .z-card, .btn-z sınıflarına ek katman.
                   ID'lere dokunulmaz; sadece class/style yönetimi.
                   ════════════════════════════════════════════════════ */

        .open-page-wrap {
            max-width: 520px;
            margin: 0 auto;
        }

        /* ── Hero ── */
        .open-hero {
            text-align: center;
            padding: 4px 0 28px;
        }

        .open-hero-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            border-radius: 22px;
            background: linear-gradient(135deg, rgba(16,185,129,.18) 0%, rgba(16,185,129,.06) 100%);
            border: 1px solid rgba(16,185,129,.22);
            font-size: 34px;
            box-shadow: 0 4px 20px rgba(16,185,129,.15);
            margin-bottom: 14px;
        }

        .open-hero-title {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 5px;
        }

        .open-hero-sub {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.55;
        }

        /* ── Premium Field Grubu ── */
        .premium-field {
            margin-bottom: 20px;
        }

        .premium-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: var(--text-muted);
            font-weight: 700;
            margin-bottom: 8px;
        }

        .lbl-required {
            color: #ef4444;
            font-size: 14px;
            line-height: 1;
        }

        /* Kapsayıcı — focus ring buraya */
        .premium-input-wrap {
            position: relative;
            border-radius: 14px;
            background: var(--surface);
            border: 1.5px solid var(--border);
            box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.04);
            transition: border-color .2s ease, box-shadow .2s ease;
            overflow: hidden;
        }

            .premium-input-wrap:focus-within {
                border-color: #10b981;
                box-shadow: 0 0 0 4px rgba(16,185,129,.12), 0 4px 16px rgba(0,0,0,.08);
            }

        /* Para birimi prefix */
        .input-prefix {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--text-muted);
            pointer-events: none;
            user-select: none;
            z-index: 1;
        }

        /* Büyük sayı input (Açılış Bakiyesi) */
        .premium-input-wrap input.premium-number {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 18px 20px 18px 54px;
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -.02em;
            line-height: 1;
            -moz-appearance: textfield;
        }

            .premium-input-wrap input.premium-number::-webkit-inner-spin-button,
            .premium-input-wrap input.premium-number::-webkit-outer-spin-button {
                -webkit-appearance: none;
            }

        /* Orta boy sayı input (Eşik) */
        .premium-input-wrap input.premium-number-sm {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 15px 20px 15px 52px;
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -.02em;
            -moz-appearance: textfield;
        }

            .premium-input-wrap input.premium-number-sm::-webkit-inner-spin-button,
            .premium-input-wrap input.premium-number-sm::-webkit-outer-spin-button {
                -webkit-appearance: none;
            }

        /* Textarea */
        .premium-input-wrap textarea.premium-textarea {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 16px 20px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            resize: vertical;
            min-height: 90px;
            font-family: inherit;
            line-height: 1.6;
        }

        .premium-hint {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 6px;
            padding-left: 2px;
            line-height: 1.5;
        }

        /* Ince bölücü çizgi */
        .open-divider {
            height: 1px;
            background: var(--border);
            margin: 24px 0;
            opacity: .5;
        }

        /* ── CTA Ana Butonu ── */
        .btn-open-cta {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            padding: 20px 24px;
            border-radius: 16px;
            border: none;
            cursor: pointer;
            background: linear-gradient(135deg, #10b981 0%, #059669 60%, #047857 100%);
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-size: 16px;
            font-weight: 800;
            letter-spacing: .01em;
            box-shadow: 0 4px 20px rgba(16,185,129,.36), 0 2px 6px rgba(0,0,0,.10);
            transition: transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .22s ease, opacity .2s;
            position: relative;
            overflow: hidden;
        }

            /* Shine sweep */
            .btn-open-cta::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,.22) 50%, transparent 60%);
                transform: translateX(-120%);
                transition: transform .55s ease;
            }

            .btn-open-cta:hover::before {
                transform: translateX(120%);
            }

            .btn-open-cta:hover {
                transform: translateY(-3px) scale(1.01);
                box-shadow: 0 10px 36px rgba(16,185,129,.44), 0 4px 12px rgba(0,0,0,.12);
            }

            .btn-open-cta:active {
                transform: translateY(0) scale(.99);
                box-shadow: 0 2px 10px rgba(16,185,129,.28);
            }

            .btn-open-cta:disabled {
                opacity: .55;
                cursor: not-allowed;
                transform: none !important;
                box-shadow: none !important;
            }

        .cta-icon {
            font-size: 22px;
            flex-shrink: 0;
        }

        .cta-text {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .cta-text-main {
            font-size: 16px;
            font-weight: 800;
            line-height: 1.15;
        }

        .cta-text-sub {
            font-size: 11px;
            font-weight: 500;
            opacity: .72;
            letter-spacing: .03em;
            margin-top: 2px;
        }

        /* İptal linki */
        .btn-cancel-link {
            display: block;
            text-align: center;
            margin-top: 14px;
            font-size: 13px;
            color: var(--text-muted);
            text-decoration: none;
            transition: color .15s;
        }

            .btn-cancel-link:hover {
                color: var(--text);
            }

        /* Alert kutusu yuvarlak köşe override */
        #alertBox > div {
            border-radius: 12px !important;
        }

        /* Spin animasyonu (yükleniyor ikonu için) */
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .premium-input-wrap input.premium-number {
                font-size: 24px;
                padding-left: 46px;
            }

            .input-prefix {
                font-size: 15px;
                left: 14px;
            }

            .btn-open-cta {
                padding: 17px 18px;
            }

            .cta-text-main {
                font-size: 15px;
            }
        }
    </style>
}

<div class="z-header">
    <div>
        <h1>🟢 Vardiya Aç</h1>
        <div class="sub">Gün başı kasa sayımını girerek vardiyayı başlatın.</div>
    </div>
    <a asp-action="Index" class="btn-z btn-z-ghost">← Geri</a>
</div>

<div id="alertBox"></div>

<div class="open-page-wrap">

    <div class="open-hero">
        <div class="open-hero-icon">🏦</div>
        <div class="open-hero-title">Gün Başı Kasa Sayımı</div>
        <div class="open-hero-sub">
            Kasadaki nakit miktarını ve uyarı eşiğini girerek<br>yeni vardiyayı başlatın.
        </div>
    </div>

    <div class="z-card" style="padding: 28px 28px 24px;">

        <div class="premium-field">
            <div class="premium-label">
                <span>💵</span>
                Açılış Bakiyesi
                <span class="lbl-required">*</span>
            </div>
            <div class="premium-input-wrap">
                <span class="input-prefix">₺</span>
                <input type="number"
                       id="openingBalance"
                       class="premium-number"
                       placeholder="0"
                       min="0"
                       step="0.01"
                       value="0"
                       inputmode="decimal" />
            </div>
            <div class="premium-hint">Gün başında kasadaki nakit miktarı.</div>
        </div>


        <div class="premium-field">
            <div class="premium-label">
                <span>⚠️</span>
                Fark Uyarı Eşiği
            </div>
            <div class="premium-input-wrap">
                <span class="input-prefix">₺</span>
                <input type="number"
                       id="threshold"
                       class="premium-number-sm"
                       placeholder="100"
                       min="0"
                       step="0.01"
                       value="100"
                       inputmode="decimal" />
            </div>
            <div class="premium-hint">Bu tutarı aşan kasa farklarında SignalR uyarısı gönderilir.</div>
        </div>

        <div class="open-divider"></div>

        <div class="premium-field" style="margin-bottom: 28px;">
            <div class="premium-label">
                <span>📝</span>
                Notlar
                <span style="font-size:10px;font-weight:500;text-transform:none;letter-spacing:0;opacity:.6;">(opsiyonel)</span>
            </div>
            <div class="premium-input-wrap">
                <textarea id="notes"
                          class="premium-textarea"
                          rows="3"
                          placeholder="Vardiyaya dair açıklama ekleyebilirsiniz…"></textarea>
            </div>
        </div>

        <button id="btnOpen" class="btn-open-cta">
            <span class="cta-icon">🚀</span>
            <span class="cta-text">
                <span class="cta-text-main">Vardiyayı Başlat</span>
                <span class="cta-text-sub">Kasa açılacak ve kayıt başlayacak</span>
            </span>
        </button>

        <a asp-action="Index" class="btn-cancel-link">İptal — Geri dön</a>

    </div>
</div>

@section Scripts {
    <script>
        // ── [FIX] Area-safe URL sabitleri ────────────────────────────────────────────
        const SHIFT_OPEN_URL   = '@Url.Action("Open", "Shift", new { area = "App" })';
        const SHIFT_DETAIL_URL = '@Url.Action("Detail", "Shift", new { area = "App" })';

        document.getElementById('btnOpen').addEventListener('click', async function () {
            const openingBalance = parseFloat(document.getElementById('openingBalance').value) || 0;
            const threshold      = parseFloat(document.getElementById('threshold').value) || 100;
            const notes          = document.getElementById('notes').value.trim();

            this.disabled = true;
            this.innerHTML = `
                <span class="cta-icon" style="display:inline-block;animation:spin .9s linear infinite">⏳</span>
                <span class="cta-text">
                    <span class="cta-text-main">Açılıyor…</span>
                    <span class="cta-text-sub">Lütfen bekleyin</span>
                </span>`;

            try {
                const res  = await fetch(SHIFT_OPEN_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ openingBalance, notes, differenceThreshold: threshold })
                });
                const data = await res.json();
                if (res.ok && data.success) {
                    window.location.href = `${SHIFT_DETAIL_URL}/${data.shiftId}`;
                } else {
                    showAlert(data.message || 'Vardiya açılamadı.');
                    resetBtn(this);
                }
            } catch {
                showAlert('Sunucu hatası. Lütfen tekrar deneyin.');
                resetBtn(this);
            }
        });

        function resetBtn(btn) {
            btn.disabled = false;
            btn.innerHTML = `
                <span class="cta-icon">🚀</span>
                <span class="cta-text">
                    <span class="cta-text-main">Vardiyayı Başlat</span>
                    <span class="cta-text-sub">Kasa açılacak ve kayıt başlayacak</span>
                </span>`;
        }

        function showAlert(msg) {
            document.getElementById('alertBox').innerHTML =
                `<div style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:12px;padding:14px 18px;font-size:13px;color:#ef4444;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                    <span style="font-size:18px;flex-shrink:0">⚠️</span>
                    <span>${msg}</span>
                 </div>`;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
}
