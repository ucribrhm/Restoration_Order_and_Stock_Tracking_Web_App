@model Restaurant_Order_and_Stock_Tracking_Web_App.MVC.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Giriş Yap";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestaurantOS — Personel Girişi</title>

    @* ── FOUC Önleme ── *@
    <script>
            (function () {
                var t = localStorage.getItem('ros-theme') || 'dark';
                document.documentElement.setAttribute('data-theme', t);
            })();
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700;1,800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>

    @* ── Arka Plan ── *@
    <div class="auth-bg" aria-hidden="true">
        <div class="auth-orb auth-orb-1"></div>
        <div class="auth-orb auth-orb-2"></div>
        <div class="auth-orb auth-orb-3"></div>
        <div class="auth-grid"></div>
    </div>

    <div class="auth-wrap">

        @* ── Geri Link ── *@
        <a class="auth-back" href="/">
            <span class="auth-back-arrow">←</span>
            Ana Sayfaya Dön
        </a>

        <div class="auth-card">

            @* ── Logo ── *@
            <div class="auth-logo">
                <span class="auth-logo-icon" aria-hidden="true">🍽</span>
                <span class="auth-logo-text">RestaurantOS</span>
                <span class="auth-logo-sub">Personel Girişi</span>
            </div>

            <h1 class="auth-title">Tekrar Hoşgeldiniz</h1>
            <p class="auth-subtitle">Hesabınıza giriş yapın</p>

            @* ── Hata Bandı ── *@
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="auth-alert" role="alert">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-action="Login" asp-area="App" asp-controller="Auth" method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                @*
                ── ADIM 1: Firma Kodu ──
                Workspace Login: hangi restorana ait olduğunu belirler.
                Label turuncu renk ile öne çıkarılır.
            *@
                <div class="auth-field">
                    <label class="auth-label auth-label--accent" asp-for="FirmaKodu">
                        🏷 Firma Kodu
                    </label>
                    <input class="auth-input @(ViewData.ModelState["FirmaKodu"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="FirmaKodu"
                           type="text"
                           autocomplete="organization"
                           autocapitalize="none"
                           autocorrect="off"
                           spellcheck="false"
                           placeholder="burger-palace-a1b2c3d4" />
                    <span class="auth-hint">Kayıt sırasında size verilen firma kodunuzu girin.</span>
                    @if (ViewData.ModelState["FirmaKodu"]?.Errors.Any() == true)
                    {
                        <span class="auth-error" asp-validation-for="FirmaKodu">@ViewData.ModelState["FirmaKodu"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ── Ayırıcı: Firma Kodu / Kullanıcı Bilgileri ── *@
                <div class="auth-field-divider">
                    <hr /><span>Kullanıcı Bilgileri</span><hr />
                </div>

                @*
                ── ADIM 2: Kullanıcı Adı ──
                Kısa kullanıcı adı (prefix'siz). Controller birleştirir.
                fullUsername = "{FirmaKodu}_{Username}"
            *@
                <div class="auth-field">
                    <label class="auth-label" asp-for="Username">Kullanıcı Adı</label>
                    <input class="auth-input @(ViewData.ModelState["Username"]?.Errors.Any() == true ? "is-invalid" : "")"
                           asp-for="Username"
                           type="text"
                           autocomplete="username"
                           autocapitalize="none"
                           autocorrect="off"
                           spellcheck="false"
                           placeholder="ahmet" />
                    @if (ViewData.ModelState["Username"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["Username"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ── ADIM 3: Şifre ── *@
                <div class="auth-field">
                    <label class="auth-label" asp-for="Password">Şifre</label>
                    <div class="auth-input-wrap">
                        <input class="auth-input @(ViewData.ModelState["Password"]?.Errors.Any() == true ? "is-invalid" : "")"
                               asp-for="Password"
                               type="password"
                               id="passwordInput"
                               autocomplete="current-password"
                               placeholder="••••••••" />
                        <button type="button" class="auth-pw-toggle" id="pwToggle"
                                aria-label="Şifreyi göster / gizle"
                                data-target="passwordInput">
                            👁
                        </button>
                    </div>
                    @if (ViewData.ModelState["Password"]?.Errors.Any() == true)
                    {
                        <span class="auth-error">@ViewData.ModelState["Password"]!.Errors.First().ErrorMessage</span>
                    }
                </div>

                @* ── Beni Hatırla + Şifremi Unuttum ── *@
                <div class="auth-remember-row">
                    <label class="auth-remember">
                        <input type="checkbox" asp-for="RememberMe" />
                        Beni Hatırla (30 gün)
                    </label>
                    <a class="auth-forgot" href="#">Şifremi Unuttum?</a>
                </div>

                @* ── Submit ── *@
                <button type="submit" class="auth-submit" id="loginSubmit">
                    <span class="auth-spinner" aria-hidden="true"></span>
                    <span class="auth-submit-text">Giriş Yap →</span>
                </button>
            </form>

            @* ── Alt Link ── *@
            <div class="auth-footer">
                Hesabınız yok mu?
                <a asp-area="" asp-controller="Landing" asp-action="Register">Ücretsiz Kayıt Olun →</a>
            </div>

        </div>
    </div>

    <script>
            (function () {
                /* ── Şifre göster / gizle ──────────────────────────────────── */
                var pwToggle = document.getElementById('pwToggle');
                if (pwToggle) {
                    pwToggle.addEventListener('click', function () {
                        var inp = document.getElementById(this.getAttribute('data-target'));
                        if (!inp) return;
                        var isHidden = inp.type === 'password';
                        inp.type = isHidden ? 'text' : 'password';
                        this.textContent = isHidden ? '🙈' : '👁';
                        this.setAttribute('aria-label', isHidden ? 'Şifreyi gizle' : 'Şifreyi göster');
                    });
                }

                /* ── Submit spinner ────────────────────────────────────────── */
                var form = document.getElementById('loginForm');
                var btn  = document.getElementById('loginSubmit');
                if (form && btn) {
                    form.addEventListener('submit', function () {
                        btn.classList.add('loading');
                    });
                }

                /* ── Tema toggle (sayfa içi) ────────────────────────────────── */
                /* Login sayfasında tema butonu yok; ama FOUC önleme çalışır. */
            })();
    </script>

</body>
</html>
