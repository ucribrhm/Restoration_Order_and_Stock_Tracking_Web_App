@* ============================================================================
   Areas/App/Views/Shared/_AppLayout.cshtml
   SaaS Areas Mimarisi — Restoran Operasyon Paneli Layout

   Sprint Redesign:
   - FOUC önleme script eklendi (<head> en başına)
   - theme.css eklendi (global dark/light değişkenleri)
   - Mevcut site.css, SignalR, APP_URLS korundu

   YETKİ MATRİSİ:
     Admin   → Dashboard, Masalar, Siparişler, Mutfak, Kullanıcılar,
               Menü, Kategori, Stok, Raporlar, Z-Raporu, Ayarlar
     Kitchen → Sadece Mutfak Ekranı
     Kasiyer → Masalar + Siparişler
     Garson  → Sadece Masalar
   ============================================================================ *@

@using Microsoft.AspNetCore.Identity
@inject UserManager<Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.ApplicationUser> UserManager
@inject SignInManager<Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.ApplicationUser> SignInManager

@{
    var activeCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var currentUser = SignInManager.IsSignedIn(User)
        ? await UserManager.GetUserAsync(User)
        : null;

    var displayName = currentUser?.FullName?.Trim();
    if (string.IsNullOrEmpty(displayName))
        displayName = currentUser?.UserName ?? "Kullanıcı";

    var userInitial = displayName.Length > 0
        ? displayName[0].ToString().ToUpper()
        : "?";

    var userRole = User.IsInRole("Admin") ? "Yönetici"
                 : User.IsInRole("Kasiyer") ? "Kasiyer"
                 : User.IsInRole("Kitchen") ? "Mutfak"
                 : "Garson";
}

<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — RestaurantOS" : "RestaurantOS")</title>

    @* ── FOUC Önleme: Sayfa görüntülenmeden tema uygulanır ────────────
       Bu script, herhangi bir CSS veya render işlemi gerçekleşmeden önce
       çalışır. localStorage'da kaydedilmiş tema varsa onu uygular.
       Böylece sayfa yüklenirken beyaz/koyu flaş (FOUC) olmaz.
    ── *@
    <script>
        (function () {
            var t = localStorage.getItem('ros-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

    @* Global tema değişkenleri (dark/light CSS custom properties) *@
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    @* Uygulama paneli stilleri *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    @* ── [v3] APP_TENANT_ID: TenantId'yi JS'e güvenli aktar ──────────────────
       SORUN: JS .withUrl('/hubs/restaurant') ile bağlanıyordu — QueryString yok.
       Hub sadece Claims/Cookie'ye bakıyordu; anonim istemcilerde her ikisi boş
       → Abort() → sistem tamamen sağır oluyordu.

       ÇÖZÜM: Razor'da TenantId'yi bir <meta> tag'ine yaz.
       JS bu meta'dan okuyarak .withUrl('/hubs/restaurant?tenantId=X') kurar.
       WebSocket handshake QueryString'i korur → Hub doğru gruba ekler.

       Garson/Admin için User.FindFirst("TenantId") doluyken çalışır.
       SysAdmin için boş string → Hub gruba eklemiyor (tasarım gereği).
    ── *@
    @{
        var _appTenantId = User.FindFirst("TenantId")?.Value ?? "";
    }
    <meta name="ros-tenant-id" content="@_appTenantId" />
</head>
<body>

    @* ── SIDEBAR ──────────────────────────────────────────────────────────── *@
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-logo">
            <div class="logo-icon">🍽️</div>
            <span class="logo-text">RestaurantOS</span>
        </div>

        <nav class="nav-section">

            @* ══════════════════════════════════════════════════════════════
               ADMIN — Tam menü erişimi
               ══════════════════════════════════════════════════════════════ *@
            @if (User.IsInRole("Admin"))
            {
                <span class="nav-label">Ana Menü</span>

                <a class="nav-item @(activeCtrl == "Home" ? "active" : "")"
                   asp-area="App" asp-controller="Home" asp-action="Index">
                    <span class="nav-icon">📊</span>
                    <span class="nav-text">Dashboard</span>
                </a>

                <a class="nav-item @(activeCtrl == "Tables" ? "active" : "")"
                   asp-area="App" asp-controller="Tables" asp-action="Index">
                    <span class="nav-icon">🪑</span>
                    <span class="nav-text">Masalar</span>
                    @if (ViewData["OccupiedCount"] is int oc && oc > 0)
                    {
                        <span class="badge">@oc</span>
                    }
                </a>

                <a class="nav-item @(activeCtrl == "Orders" ? "active" : "")"
                   asp-area="App" asp-controller="Orders" asp-action="Index">
                    <span class="nav-icon">🧾</span>
                    <span class="nav-text">Siparişler</span>
                    @if (ViewData["ActiveOrderCount"] is int ao && ao > 0)
                    {
                        <span class="badge">@ao</span>
                    }
                </a>

                <span class="nav-label">Mutfak</span>

                <a class="nav-item @(activeCtrl == "Kitchen" ? "active" : "")"
                   asp-area="App" asp-controller="Kitchen" asp-action="Display">
                    <span class="nav-icon">🍳</span>
                    <span class="nav-text">Mutfak Ekranı</span>
                </a>

                <span class="nav-label">Yönetim</span>

                <a class="nav-item @(activeCtrl == "User" ? "active" : "")"
                   asp-area="App" asp-controller="User" asp-action="Index">
                    <span class="nav-icon">👥</span>
                    <span class="nav-text">Kullanıcılar</span>
                </a>

                <a class="nav-item @(activeCtrl == "Menu" ? "active" : "")"
                   asp-area="App" asp-controller="Menu" asp-action="Index">
                    <span class="nav-icon">🍕</span>
                    <span class="nav-text">Menü</span>
                </a>

                <a class="nav-item @(activeCtrl == "Category" ? "active" : "")"
                   asp-area="App" asp-controller="Category" asp-action="Index">
                    <span class="nav-icon">🏷️</span>
                    <span class="nav-text">Kategori</span>
                </a>

                <a class="nav-item @(activeCtrl == "Stock" ? "active" : "")"
                   asp-area="App" asp-controller="Stock" asp-action="Index">
                    <span class="nav-icon">📦</span>
                    <span class="nav-text">Stok</span>
                </a>

                <span class="nav-label">Raporlar</span>

                <a class="nav-item @(activeCtrl == "Reports" ? "active" : "")"
                   asp-area="App" asp-controller="Reports" asp-action="Index">
                    <span class="nav-icon">📈</span>
                    <span class="nav-text">Raporlar</span>
                </a>

                <a class="nav-item @(activeCtrl == "Shift" ? "active" : "")"
                   asp-area="App" asp-controller="Shift" asp-action="Index">
                    <span class="nav-icon">⏱️</span>
                    <span class="nav-text">Z-Raporu</span>
                </a>

                <span class="nav-label">Sistem</span>

                <a class="nav-item @(activeCtrl == "Settings" ? "active" : "")"
                   asp-area="App" asp-controller="Settings" asp-action="Index">
                    <span class="nav-icon">⚙️</span>
                    <span class="nav-text">Ayarlar</span>
                </a>
            }

            @* ══════════════════════════════════════════════════════════════
               KITCHEN — Sadece Mutfak Ekranı
               ══════════════════════════════════════════════════════════════ *@
            @if (User.IsInRole("Kitchen"))
            {
                <span class="nav-label">Mutfak</span>

                <a class="nav-item @(activeCtrl == "Kitchen" ? "active" : "")"
                   asp-area="App" asp-controller="Kitchen" asp-action="Display">
                    <span class="nav-icon">🍳</span>
                    <span class="nav-text">Mutfak Ekranı</span>
                </a>
            }

            @* ══════════════════════════════════════════════════════════════
               KASİYER — Masalar + Siparişler
               ══════════════════════════════════════════════════════════════ *@
            @if (User.IsInRole("Kasiyer"))
            {
                <span class="nav-label">Ana Menü</span>

                <a class="nav-item @(activeCtrl == "Tables" ? "active" : "")"
                   asp-area="App" asp-controller="Tables" asp-action="Index">
                    <span class="nav-icon">🪑</span>
                    <span class="nav-text">Masalar</span>
                    @if (ViewData["OccupiedCount"] is int oc2 && oc2 > 0)
                    {
                        <span class="badge">@oc2</span>
                    }
                </a>

                <a class="nav-item @(activeCtrl == "Orders" ? "active" : "")"
                   asp-area="App" asp-controller="Orders" asp-action="Index">
                    <span class="nav-icon">🧾</span>
                    <span class="nav-text">Siparişler</span>
                    @if (ViewData["ActiveOrderCount"] is int ao2 && ao2 > 0)
                    {
                        <span class="badge">@ao2</span>
                    }
                </a>
            }

            @* ══════════════════════════════════════════════════════════════
               GARSON — Sadece Masalar
               ══════════════════════════════════════════════════════════════ *@
            @if (User.IsInRole("Garson"))
            {
                <span class="nav-label">Ana Menü</span>

                <a class="nav-item @(activeCtrl == "Tables" ? "active" : "")"
                   asp-area="App" asp-controller="Tables" asp-action="Index">
                    <span class="nav-icon">🪑</span>
                    <span class="nav-text">Masalar</span>
                    @if (ViewData["OccupiedCount"] is int oc3 && oc3 > 0)
                    {
                        <span class="badge">@oc3</span>
                    }
                </a>
            }

        </nav>

        @* ── Sidebar Footer: Kullanıcı Bilgisi + Çıkış ──────────────────── *@
        <div class="sidebar-footer">
            <div class="avatar">@userInitial</div>
            <div class="avatar-info">
                <div class="avatar-name">@displayName</div>
                <div class="avatar-role">@userRole</div>
            </div>
            @* asp-area="App" ZORUNLU — yoksa ambient area yokken /Auth/Logout üretir *@
            <form asp-area="App" asp-controller="Auth" asp-action="Logout"
                  method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit"
                        title="Çıkış Yap"
                        style="background:none;border:1px solid;border-radius:4px;cursor:pointer;
                    border-color:dimgrey;color:var(--text);font-size:1.1rem;padding:4px;">
                    🚪 Çıkış Yap
                </button>
            </form>
        </div>

    </aside>

    @* ── MAIN ──────────────────────────────────────────────────────────────── *@
    <div class="main" id="main">

        <header class="topbar">
            <button class="topbar-toggle" id="toggleBtn">☰</button>

            <div class="topbar-breadcrumb">
                RestaurantOS › <span>@(ViewData["Title"] ?? "Dashboard")</span>
            </div>

            <div class="topbar-right">
                <div class="topbar-clock" id="clock">--:--</div>

                <button class="notif-btn" title="Bildirimler">
                    🔔
                    @if (ViewData["HasLowStock"] is bool low && low)
                    {
                        <span class="notif-dot"></span>
                    }
                </button>

                <div class="theme-toggle" id="themeToggle"></div>
            </div>
        </header>

        <main class="content">
            @RenderBody()
        </main>

    </div>

    @* ── APP_URLS: Tüm controller action URL'leri merkezi tanım ──────────── *@
    <script>
        // [v3] APP_TENANT_ID — Hub bağlantısı için TenantId, meta tag'den okunur.
        // Tüm View JS dosyaları window.APP_TENANT_ID ile erişir.
        window.APP_TENANT_ID = (document.querySelector('meta[name="ros-tenant-id"]')?.content ?? '').trim();

        window.APP_URLS = {
            // ── Tables ───────────────────────────────────────────────────
            tablesCreate:           '@Url.Action("Create", "Tables", new { area = "App" })',
            tablesReserve:          '@Url.Action("Reserve", "Tables", new { area = "App" })',
            tablesCancelReserve:    '@Url.Action("CancelReserve", "Tables", new { area = "App" })',
            tablesDelete:           '@Url.Action("Delete", "Tables", new { area = "App" })',
            tablesMergeOrder:       '@Url.Action("MergeOrder", "Tables", new { area = "App" })',
            tablesServeReadyItems:  '@Url.Action("ServeReadyItems", "Tables", new { area = "App" })',
            tablesDismissWaiter:    '@Url.Action("DismissWaiter", "Tables", new { area = "App" })',
            // ── Orders ───────────────────────────────────────────────────
            ordersCreate:           '@Url.Action("Create", "Orders", new { area = "App" })',
            ordersUpdateItemStatus: '@Url.Action("UpdateItemStatus", "Orders", new { area = "App" })',
            ordersAddItemBulk:      '@Url.Action("AddItemBulk", "Orders", new { area = "App" })',
            ordersAddPayment:       '@Url.Action("AddPayment", "Orders", new { area = "App" })',
            ordersCloseZero:        '@Url.Action("CloseZero", "Orders", new { area = "App" })',
            ordersCancelItem:       '@Url.Action("CancelItem", "Orders", new { area = "App" })',
            // ── Menu ─────────────────────────────────────────────────────
            menuCreate:             '@Url.Action("Create", "Menu", new { area = "App" })',
            menuEdit:               '@Url.Action("Edit", "Menu", new { area = "App" })',
            menuDelete:             '@Url.Action("Delete", "Menu", new { area = "App" })',
            menuGetById:            '@Url.Action("GetById", "Menu", new { area = "App" })',
            menuIndex:              '@Url.Action("Index", "Menu", new { area = "App" })',
            // ── Category ─────────────────────────────────────────────────
            categoryCreate:         '@Url.Action("Create", "Category", new { area = "App" })',
            categoryEdit:           '@Url.Action("Edit", "Category", new { area = "App" })',
            categoryDelete:         '@Url.Action("Delete", "Category", new { area = "App" })',
            categoryGetById:        '@Url.Action("GetById", "Category", new { area = "App" })',
            categoryIndex:          '@Url.Action("Index", "Category", new { area = "App" })',
            // ── Stock ─────────────────────────────────────────────────────
            stockUpdateStock:       '@Url.Action("UpdateStock", "Stock", new { area = "App" })',
            stockToggleTrack:       '@Url.Action("ToggleTrack", "Stock", new { area = "App" })',
            stockGetHistory:        '@Url.Action("GetHistory", "Stock", new { area = "App" })',
            stockPdfReport:         '@Url.Action("GenerateStockPdfReport", "Stock", new { area = "App" })',
            // ── Auth ─────────────────────────────────────────────────────
            authLogin:              '@Url.Action("Login", "Auth", new { area = "App" })',
        };
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @* SignalR — App Area layout'unda her sayfada yüklü *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
