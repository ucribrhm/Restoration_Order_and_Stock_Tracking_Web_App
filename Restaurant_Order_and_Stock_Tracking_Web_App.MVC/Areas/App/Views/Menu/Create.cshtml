@{
    ViewData["Title"] = "Yeni Ürün";
    Layout = "_AppLayout";
    var categories = ViewData["Categories"] as List<Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.Category>
                  ?? new List<Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.Category>();
}

@section Styles {
    <link href="~/css/Views/Menu/Create.css" rel="stylesheet" asp-append-version="true" />
    <style>
        /* ─── Görsel yükleme alanı ─── */
        .image-upload-zone {
            border: 2px dashed rgba(255,255,255,.15);
            border-radius: 12px;
            padding: 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: border-color .2s, background .2s;
            position: relative;
        }

        [data-theme="light"] .image-upload-zone {
            border-color: #d1d5db;
        }

        .image-upload-zone:hover {
            border-color: #6366f1;
            background: rgba(99,102,241,.04);
        }

        .image-upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

        .image-upload-icon {
            font-size: 2rem;
            margin-bottom: .5rem;
            opacity: .5;
        }

        .image-upload-label {
            font-size: .85rem;
            opacity: .6;
        }

        .image-preview-wrap {
            margin-top: .75rem;
            display: none;
        }

            .image-preview-wrap img {
                max-height: 160px;
                border-radius: 8px;
                object-fit: cover;
                border: 1px solid rgba(255,255,255,.1);
            }

        [data-theme="light"] .image-preview-wrap img {
            border-color: #e5e7eb;
        }

        .image-preview-name {
            font-size: .78rem;
            opacity: .55;
            margin-top: .4rem;
        }
    </style>
}

<div class="form-page">
    <div class="page-header">
        <h1 class="page-title">➕ Yeni Ürün</h1>
        <a asp-action="Index" class="btn btn-ghost">← Geri</a>
    </div>

    <div class="card">
        <form id="createForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div id="alertBox" class="alert alert-error" style="display:none;"></div>

            @* ── Dil Sekmeleri ── *@
            <div class="lang-tabs">
                <button type="button" class="lang-tab active" onclick="switchLangTab('tr',this)">🇹🇷 Türkçe</button>
                <button type="button" class="lang-tab" onclick="switchLangTab('en',this)">🇬🇧 English</button>
                <button type="button" class="lang-tab" onclick="switchLangTab('ar',this)">🇸🇦 العربية</button>
                <button type="button" class="lang-tab" onclick="switchLangTab('ru',this)">🇷🇺 Русский</button>
            </div>

            @* TR *@
            <div class="lang-panel active" id="panel-tr">
                <div class="form-group">
                    <label class="form-label">Ürün Adı (TR) *</label>
                    <input type="text" id="c_name" class="form-control" maxlength="200" />
                </div>
                <div class="form-group">
                    <label class="form-label">Açıklama (TR)</label>
                    <textarea id="c_description" class="form-control" rows="2"></textarea>
                </div>
            </div>

            @* EN *@
            <div class="lang-panel" id="panel-en" style="display:none">
                <div class="form-group">
                    <label class="form-label">Product Name (EN)</label>
                    <input type="text" id="c_nameEn" class="form-control" maxlength="200" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description (EN)</label>
                    <textarea id="c_descriptionEn" class="form-control" rows="2"></textarea>
                </div>
            </div>

            @* AR *@
            <div class="lang-panel" id="panel-ar" style="display:none">
                <div class="form-group">
                    <label class="form-label">اسم المنتج (AR)</label>
                    <input type="text" id="c_nameAr" class="form-control" dir="rtl" maxlength="200" />
                </div>
                <div class="form-group">
                    <label class="form-label">الوصف (AR)</label>
                    <textarea id="c_descriptionAr" class="form-control" dir="rtl" rows="2"></textarea>
                </div>
            </div>

            @* RU *@
            <div class="lang-panel" id="panel-ru" style="display:none">
                <div class="form-group">
                    <label class="form-label">Название (RU)</label>
                    <input type="text" id="c_nameRu" class="form-control" maxlength="200" />
                </div>
                <div class="form-group">
                    <label class="form-label">Описание (RU)</label>
                    <textarea id="c_descriptionRu" class="form-control" rows="2"></textarea>
                </div>
            </div>

            @* ── Ortak Alanlar ── *@
            <div class="form-row" style="margin-top:16px">
                <div class="form-group">
                    <label class="form-label">Kategori *</label>
                    <select id="c_categoryId" name="categoryId" class="form-control" required>
                        <option value="">— Seçin —</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fiyat (₺) *</label>
                    <input type="number" id="c_price" name="menuItemPriceStr" class="form-control" min="0" step="0.01" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Kısa Açıklama <span style="opacity:.5">(menü listesinde gösterilir)</span></label>
                <textarea id="c_description" name="description" class="form-control" rows="2"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Detaylı Açıklama <span style="opacity:.5">(QR menü ürün detayında gösterilir)</span></label>
                <textarea id="c_detailedDescription" name="detailedDescription" class="form-control" rows="4"
                          placeholder="Malzemeler, pişirme yöntemi, sunum önerisi..."></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Ürün Fotoğrafı <span style="opacity:.5">(maks. 5 MB — JPG, PNG, WEBP)</span></label>
                <div class="image-upload-zone" id="uploadZone">
                    <input type="file" id="c_imageFile" name="imageFile" accept=".jpg,.jpeg,.png,.webp,.gif" />
                    <div class="image-upload-icon">🖼️</div>
                    <div class="image-upload-label">Fotoğraf seçmek için tıklayın veya sürükleyin</div>
                    <div class="image-preview-wrap" id="previewWrap">
                        <img id="previewImg" src="#" alt="Önizleme" />
                        <div class="image-preview-name" id="previewName"></div>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Stok Miktarı</label>
                    <input type="number" id="c_stock" name="stockQuantity" class="form-control" value="0" min="0" />
                </div>
                <div class="form-group" style="display:flex;flex-direction:column;justify-content:flex-end;">
                    <label class="form-label">Stok Takibi</label>
                    <div class="toggle-group">
                        <label class="toggle-switch">
                            <input type="checkbox" id="c_trackStock" name="trackStock" value="true" />
                            <span class="toggle-slider"></span>
                        </label>
                        <span>Takip Et</span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    Gösterim Sırası
                    <span style="opacity:.5;font-size:.82em;">(menüde sıralama için, küçük sayı = üstte)</span>
                </label>
                <input type="number" id="c_displayOrder" name="displayOrder" class="form-control"
                       value="0" min="0" style="max-width:160px" />
            </div>

            <div class="form-group">
                <label class="form-label">Satışa Açık</label>
                <div class="toggle-group">
                    <label class="toggle-switch">
                        <input type="checkbox" id="c_isAvailable" name="isAvailable" value="true" checked />
                        <span class="toggle-slider"></span>
                    </label>
                    <span>Mevcut</span>
                </div>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:.6rem;margin-top:1.5rem;">
                <a asp-action="Index" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">💾 Kaydet</button>
            </div>
        </form>
    </div>
</div>

<style>
    .lang-tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .lang-tab {
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid var(--border,#e5e7eb);
        background: var(--surface2,#f9fafb);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all .18s;
    }

        .lang-tab.active {
            background: var(--accent,#f97316);
            color: #fff;
            border-color: var(--accent,#f97316);
        }
</style>

@section Scripts {
    <script src="~/js/Views/Menu/Create.js" asp-append-version="true"></script>
}